<Window x:Class="HAHATalk.Controls.AddFriendControl"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:local="clr-namespace:HAHATalk.Controls"
        xmlns:fa6="http://schemas.fontawesome.com/icons/svg"
        xmlns:libConv="clr-namespace:WPFLib.Converters;assembly=WPFLib"
        mc:Ignorable="d" 
       
        d:DesignWidth="350"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Window.Resources>
        <libConv:BooleanToVisibilityConverter x:Key="BoolToVis"/>        
    </Window.Resources>

    <Grid Background="Transparent">
        
        <Border Background="White"
                CornerRadius="15"
                Width="320"
                Height="480"
                Margin="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" 
                                  ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" 
                      MouseLeftButtonDown="Header_MouseLeftButtonDown"
                      Margin="20 15 20 0">
                    <TextBlock Text="친구 추가" FontSize="18"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Click="CloseButton_Click">
                        <fa6:SvgAwesome Icon="Solid_Xmark" Width="18" PrimaryColor="#333333"/>
                    </Button>
                </Grid>

                <StackPanel Grid.Row="1" Margin="25 10 25 0">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0 0 30 0">
                                <TextBlock Text="연락처로 추가" FontWeight="Bold" 
                                           FontSize="14"/>
                                <Rectangle Height="2" Fill="#3C1E1E" Margin="0 5 0 0"/>
                            </StackPanel>
                            <TextBlock Text="ID로 추가" FontSize="14" Foreground="#AAAAAA"
                                       Cursor="Hand"/>
                            
                        </StackPanel>
                        <Border BorderThickness="0 0 0 1" BorderBrush="#F0F0F0"
                                VerticalAlignment="Bottom"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="30 40 30 0">
                    <Grid Margin="0 0 0 30">
                        <TextBox x:Name="NameInput" Text="{Binding NewFriendName, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="20" FontSize="15" 
                                 BorderThickness="0 0 0 1"
                                 BorderBrush="#EEEEEE" Padding="0 8"
                                 Background="Transparent"/>
                        <TextBlock Text="이름" IsHitTestVisible="False" 
                                   Foreground="#CCCCCC" FontSize="15"
                                   VerticalAlignment="Center" Margin="2 0 0 0"
                                   Visibility="{Binding Text.IsEmpty, ElementName=NameInput, 
                                    Converter={StaticResource BoolToVis}}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" 
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding NewFriendName.Length, FallbackValue=0}"
                                       FontSize="11" Foreground="#888888"/>
                            <TextBlock Text="/20" FontSize="11" Foreground="#DDDDDD"/>
                        </StackPanel>
                    </Grid>

                    <Grid  Margin="0 0 0 30">
                        <TextBox x:Name="EmaiInput" Text="{Binding NewFriendEmail, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15" BorderThickness="0 0 0 1" 
                                 BorderBrush="#EEEEEE" Padding="0 8"
                                 Background="Transparent"/>
                        <TextBlock Text="이메일 주소" IsHitTestVisible="False"
                                   Foreground="#CCCCCC" FontSize="15"
                                   VerticalAlignment="Center"
                                   Margin="2 0 0 0"
                                   Visibility="{Binding Text.IsEmpty, ElementName=EmaiInput, Converter={StaticResource BoolToVis}}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="+82" FontSize="15" VerticalAlignment="Center"
                                   Margin="0 0 8 0"/>
                        <fa6:SvgAwesome Grid.Column="1" Icon="Solid_ChevronDown" 
                                        Width="10" PrimaryColor="#888888" Margin="0 2 15 0"/>
                        <TextBox Grid.Column="2" Text="{Binding NewFriendPhone, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="15" BorderThickness="0 0 0 1"
                                 BorderBrush="#EEEEEE" Padding="0 8"
                                 Background="Transparent"/>                        
                    </Grid>                    
                </StackPanel>

                <Button Grid.Row="3" Content="친구 추가"
                        Command="{Binding ConfirmAddFriendCommand}"
                        Width="100" Height="42" HorizontalAlignment="Right"
                        Margin="0 0 25 25" Background="#FEE500"
                        Foreground="#3C1E1E" FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>          
        </Border> 
    </Grid>
</Window>
