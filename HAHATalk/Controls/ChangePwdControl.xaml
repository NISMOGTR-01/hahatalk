<UserControl x:Class="HAHATalk.Controls.ChangePwdControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HAHATalk.Controls"
             xmlns:fa6="http://schemas.fontawesome.com/icons/svg"
             xmlns:controls="clr-namespace:WPFLib.Controls;assembly=WPFLib"
             mc:Ignorable="d" 
             d:DesignHeight="550" 
             d:DesignWidth="350"
             Background="{StaticResource ColorPrimary}"
             >
    <UserControl.Resources>
        <Style x:Key="ValidationTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ValidationText}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>            
        
        <Style x:Key="EmailValidationTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding EmailValidationText}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    
    
    <Grid Margin="20 40 20 20">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.3*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        
        <!-- LOGO -->
        <fa6:SvgAwesome Icon="Brands_Rocketchat"
                        Margin="20"
                        PrimaryColor="{StaticResource ColorGray}"/>
        
        <!-- BODY -->
        <StackPanel Grid.Row="1" Margin="30 10">
            <controls:TextBoxControl
                x:Name="email"
                Text="{Binding Email}"
                WaterMarkText="이메일"
                Background="White"
                Height="{StaticResource MainElementHeight}"
                Margin="0 0 0 10"
                Validating="{Binding ValidatingDict[Email]}"
                />
            
            <!-- 2026.03.13 이메일 TextBox 추가 -->            
            <TextBlock Text="{Binding EmailValidationText}"
                       Style="{StaticResource EmailValidationTextStyle}"
                       Foreground="{Binding EmailValidationTextColor}"
                       />

            <controls:PasswordBoxControl
                Password="{Binding OldPassword}"
                Background="White"
                WaterMarkText="기존 비밀번호"
                Height="{StaticResource MainElementHeight}"
                Margin="0 5 0 10"
                Validating="{Binding ValidatingDict[OldPassword]}"
                />

            <controls:PasswordBoxControl 
                Password="{Binding NewPassword}"
                Background="White"
                WaterMarkText="새로운 비밀번호"
                Height="{StaticResource MainElementHeight}"
                Margin="0 5 0 10"
                Validating="{Binding ValidatingDict[NewPassword]}"
                />

            <TextBlock Text="{Binding ValidationText}"
                       Style="{StaticResource ValidationTextStyle}"
                       Foreground="Red"
                       Margin="0 5 0 0 "
                       />


            <Button Content="비밀번호 변경"
                    Command="{Binding ChangePwdCommand}"
                    Height="{StaticResource MainElementHeight}"
                    Margin="0 10 0 10"/>
        </StackPanel>
        
        <!--Bottom-->
        <local:MainNaviControl Grid.Row="2"
                               HideButton="ChangePwd"/>
    </Grid>
    <!--
    <Grid Background="SkyBlue">
        <TextBlock Text="Change Password Control"/>
    </Grid>
    -->
</UserControl>
