<UserControl x:Class="HAHATalk.Controls.LoginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HAHATalk.Controls" 
             xmlns:fa6="http://schemas.fontawesome.com/icons/svg"
             xmlns:controls="clr-namespace:WPFLib.Controls;assembly=WPFLib"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="350"
             Background="{StaticResource ColorPrimary}">   
    <Grid 
          Margin="20 40 20 20">
        <Grid.RowDefinitions>
            <RowDefinition  Height="1.3*"/>
            <RowDefinition  Height="3*"/>
            <RowDefinition  Height="30"/>
        </Grid.RowDefinitions>
    
        <!-- Logo -->
        <fa6:SvgAwesome Icon="Brands_Rocketchat" 
                        Margin="20"
                        PrimaryColor="{StaticResource ColorGray}"/>
        <!-- Body -->
        <StackPanel Grid.Row="1" 
                    Margin="30 10">
            <controls:ComboBoxControl Background="White"
                                      Height="35"
                                      WaterMarkText="이메일을 입력하세요."                                     
                                      IsEditable="True"
                                      ItemsSource="{Binding Emails}"
                                      Text="{Binding SelectedEmail, UpdateSourceTrigger=PropertyChanged}"/>
            
            <!-- <ComboBox Height="{StaticResource ElementHeight}"/>-->
            <controls:PasswordBoxControl 
                x:Name="PwBox"
                Background="White"
                WaterMarkText="비밀번호를 입력하세요."
                WaterMarkTextColor="Blue"
                Password="12345"
                Height="{StaticResource MainElementHeight}"
                Margin="0 5 0 0"/>

            <Button 
                    Command="{Binding LoginCommand}"
                    CommandParameter="{Binding ElementName=PwBox}"
                    Height="{StaticResource MainElementHeight}"                    
                    Margin="0 10 0 0">
                <Grid>
                    <TextBlock  Text="로그인"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <fa6:SvgAwesome Icon="Solid_CircleNotch"
                                    Spin="True"
                                    Width="18"
                                    PrimaryColor="White">
                        <fa6:SvgAwesome.Style>
                            <Style TargetType="{x:Type fa6:SvgAwesome}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </fa6:SvgAwesome.Style>
                    </fa6:SvgAwesome>               
                </Grid>                
            </Button>

            <TextBlock Text="{Binding ValidationText}"
                       Foreground="#FF5C5C"
                       HorizontalAlignment="Center"
                       Margin="0 10 0 0"
                       FontWeight="Bold"/>

            <!-- 또는 Seperator -->
            <Grid Height="{StaticResource MainElementHeight}" Margin="0 10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Separator Grid.Column="0"
                           VerticalAlignment="Center"                           
                           Margin="0 0 15 0"
                           />
                <TextBlock Grid.Column="1" 
                           Text="또는"
                           VerticalAlignment="Center"
                           Margin="10 0"/>
                <Separator Grid.Column="2"/>
            </Grid>

            <Button Content="QR CODE 로그인" 
                    Height="{StaticResource MainElementHeight}"/>

            <StackPanel Orientation="Horizontal" 
                        Height="{StaticResource MainElementHeight}">
                <CheckBox Content="자동 로그인"
                          VerticalContentAlignment="Center"/>
                <Button BorderThickness="2"
                          Background="#FFEDD607"
                          BorderBrush="#FFA99900"
                          Height="17"
                          Width="17"
                          Margin="5 0">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="30"/>                            
                        </Style>
                    </Button.Resources>
                    <fa6:SvgAwesome Icon="Solid_Info" PrimaryColor="#ffa99900"/>
                </Button>
                
            </StackPanel>
        </StackPanel>
    
        <!-- Bottom -->
        <local:MainNaviControl Grid.Row="2" HideButton="Login"/>
    </Grid>
</UserControl>
